# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Google AI Studio key (Nano Banana 2 image gen + Veo i2v + prompt drafting)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# ElevenLabs key (voiceover TTS)
# Get one at https://elevenlabs.io -> Profile -> API keys
ELEVENLABS_API_KEY=your_key_here

# HuggingFace read token — ONLY for the gameplay pipeline's speaker diarization
# (pyannote). Optional: without it, gameplay clips fall back to single-speaker
# captions. Get one at https://huggingface.co/settings/tokens and accept the
# model terms for pyannote/speaker-diarization-3.1 and pyannote/segmentation-3.0.
HF_TOKEN=your_token_here
