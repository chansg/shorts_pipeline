# Secrets
.env

# Python
__pycache__/
*.pyc
.venv/
venv/

# IDE
.idea/

# Generated media & episode artifacts (large binaries, reproducible from manifests)
output/
episodes/
prompts/*_candidates/
assets/images/
assets/cutaways/
assets/music/

# Imported audio is user-supplied / loudnorm'd at build time (keep the folder)
assets/sfx/imported/*
!assets/sfx/imported/.gitkeep
refs/*.png
refs/*.jpg
refs/*.jpeg
refs/*.webp

# Gameplay pipeline: per-clip work + finished Shorts live under output/ (already
# ignored above). Overlay assets are user-supplied; keep only the placeholder.
overlays/*
!overlays/.gitkeep
!overlays/like_subscribe_placeholder.png

# Scratch
_aria_extract/
manifests/*.state.json
